# OpenAI Configuration
MAIX_AGENT_OPENAI_API_KEY=sk-xxx
MAIX_AGENT_OPENAI_BASE_URL=https://api.openai.com/v1
MAIX_AGENT_OPENAI_MODEL=gpt-4o

# Anthropic Configuration
MAIX_AGENT_ANTHROPIC_API_KEY=sk-ant-xxx
MAIX_AGENT_ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Default Provider (openai or anthropic)
MAIX_AGENT_DEFAULT_PROVIDER=openai

# Database
MAIX_AGENT_DB_PATH=./data/maix.db

# Log Level (debug, info, warn, error)
MAIX_AGENT_LOG_LEVEL=info

# Agent Mode (plan, agent, yolo)
MAIX_AGENT_DEFAULT_MODE=agent

# Model Router (enable/disable automatic task classification)
MAIX_AGENT_ENABLE_MODEL_ROUTER=false

# MCP Client (enable/disable MCP protocol support)
MAIX_AGENT_ENABLE_MCP=false

# MCP Servers (JSON format: {"server_name": {"command": "path/to/server", "args": []}})
MAIX_AGENT_MCP_SERVERS={}

# Skills Directory
MAIX_AGENT_SKILLS_DIR=./skills

# WebSocket Monitor Port (0 to disable)
MAIX_AGENT_WS_PORT=8765