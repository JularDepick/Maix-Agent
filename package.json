{
  "name": "maix-agent",
  "version": "1.0.1",
  "description": "Maix-Agent - AI Agent with TUI and Backend separation",
  "type": "module",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "scripts": {
    "build": "node scripts/bunbuild-tui-with-backend-windows_x64.mjs",
    "build:tui-shell": "node scripts/bunbuild-tui-shell-windows_x64.mjs",
    "build:backend-solo": "node scripts/bunbuild-backend-solo-windows_x64.mjs",
    "build:tui-with-backend": "node scripts/bunbuild-tui-with-backend-windows_x64.mjs",
    "esbuild": "node scripts/esbuild-tui-with-backend.mjs",
    "esbuild:tui-shell": "node scripts/esbuild-tui-shell.mjs",
    "esbuild:backend-solo": "node scripts/esbuild-backend-solo.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "chalk": "^5.3.0",
    "dotenv": "^16.4.0",
    "highlight.js": "^11.9.0",
    "marked": "^12.0.0",
    "openai": "^4.0.0",
    "sql.js": "^1.10.0",
    "terminal-kit": "^3.0.1",
    "uuid": "^9.0.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/sql.js": "^1.4.11",
    "@types/uuid": "^9.0.0",
    "@types/ws": "^8.5.10",
    "esbuild": "^0.28.1",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
